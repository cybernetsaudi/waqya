# Copy this file to .env and fill in real values. NEVER commit .env or real keys here.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# NewsAPI — https://newsapi.org (free tier ~100 req/day; RSS + Google News cover more)
NEWSAPI_KEY=your-newsapi-key

# Optional: GNews https://gnews.io (100 free req/day) — not wired yet; use extra_sources.yaml RSS instead
# GNEWS_API_KEY=

# WordPress REST API
WP_URL=https://waqya.com
WP_USER=your-wordpress-username
WP_APP_PASSWORD=your-wordpress-application-password

# Telegram Bot API — create via @BotFather, then message your bot and use getUpdates for chat ID
TELEGRAM_BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your-telegram-user-chat-id

# Pexels — free stock photos for featured images (https://www.pexels.com/api/)
PEXELS_API_KEY=your-pexels-api-key

# Optional: IndexNow key for faster Bing/Yandex indexing (host a {key}.txt on site root)
INDEXNOW_KEY=
